# ─────────────────────────────────────────────────────────────
# Phase 1 — already required (Step 1 landing + auth + waitlist)
# ─────────────────────────────────────────────────────────────

# Supabase (eu-north-1, Stockholm)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Local dev shortcut: set true to skip auth and pretend to be an admin user.
# Never works in production (guarded on NODE_ENV === "development").
DEV_BYPASS_AUTH=false

# Escape hatch if auto-creating the dev user fails (e.g. service-role API
# quirks or your Supabase project has stricter policies). Sign up once via
# /da/signup?invite=<code>, grab your user's id from Supabase → Authentication
# → Users, and paste it here. DEV_BYPASS_AUTH will pretend to be that real
# user and skip the auto-create. Leave blank to use the default behaviour.
DEV_USER_ID=
DEV_USER_EMAIL=

# Pre-launch invite gate. Share /da/signup?invite=<this-value> with testers.
# Without it set, /da/signup shows a "waitlist only" holding card.
EARLY_ACCESS_INVITE_CODE=

# Feature flag: enables the "Fortsæt med Google" button on the login/signup
# cards. Leave unset in Production for now — we'll flip to true once we're
# confident the Google OAuth round-trip works reliably. Set to "true" in
# .env.local to test the real flow against your local dev server.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=

# Feature flag: opens public self-signup at /da/signup (no invite code needed)
# and rewires "Har du ikke en konto?" on the login card to point straight at
# /signup instead of the waitlist. Leave unset for invite-only access.
NEXT_PUBLIC_PUBLIC_SIGNUP_ENABLED=

# Email (Resend) — EU region
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@lektiero.dk
RESEND_AUDIENCE_ID=

# ─────────────────────────────────────────────────────────────
# Phase 2 — AI pipeline (photo → hint flow)
# Provision these when starting the core flow work.
# ─────────────────────────────────────────────────────────────

# Azure OpenAI — Sweden Central only (GDPR, matches privacy policy).
# Use the Foundry project v1 endpoint (ends in /openai/v1 with NO trailing slash).
# Example shape:
#   https://<resource>.services.ai.azure.com/api/projects/<project-name>/openai/v1
# Classic Azure OpenAI endpoints also work:
#   https://<resource>.openai.azure.com/openai/v1
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
# One deployment handles both vision extraction and Socratic streaming.
# Must be deployed as Data Zone Standard in Sweden Central (GDPR).
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini

# AI mode: "live" calls Azure, "test" returns canned mocks.
#   live  — requires AZURE_OPENAI_ENDPOINT + AZURE_OPENAI_KEY above.
#   test  — skips Azure entirely, returns fixture data (safe for demos + dev).
# If unset, defaults to live when Azure is configured, test otherwise.
# Admins can also flip it per-browser via the ⚙ dev panel in the kid flow.
AI_MODE=live

# Supabase Storage bucket for homework photos (create as PRIVATE, 24h TTL policy).
SUPABASE_STORAGE_BUCKET=homework-photos

# ─────────────────────────────────────────────────────────────
# Phase 3 — Parent Coach email (nightly cron)
# ─────────────────────────────────────────────────────────────

# Shared secret that Vercel Cron sends in the Authorization header so the
# /api/cron/parent-coach endpoint can reject unauthenticated hits.
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ─────────────────────────────────────────────────────────────
# Phase 4 — Voice (STT/TTS via Azure AI Speech, Sweden Central)
# Full GDPR coverage under existing Azure EU tenant.
# ─────────────────────────────────────────────────────────────

# Feature flag. Set to "true" once Azure Speech keys are provisioned and
# you want to expose the Snak/Skriv toggle + kid-facing mic UI.
NEXT_PUBLIC_VOICE_ENABLED=

# ── Azure AI Speech (Sweden Central, GDPR) ───────────────────
# Portal → Create resource → "Speech" → Region: Sweden Central.
# After creation: resource → "Keys and Endpoint" (left sidebar) → copy KEY 1.
# Region is the lowercase code, e.g. "swedencentral".
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=swedencentral

# Danish Neural TTS voice. Admin can switch via /da/admin/voice.
#   da-DK-ChristelNeural  (female)
#   da-DK-JeppeNeural     (male)
AZURE_SPEECH_TTS_VOICE=da-DK-ChristelNeural
